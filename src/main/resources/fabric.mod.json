{
  "schemaVersion": 1,
  "id": "sapphire",
  "version": "${version}",
  "name": "Sapphire",
  "description": "An mod that loads Minecraft through SDL3 instead of GLFW, as an interesting Proof-Of-Concept",
  "authors": [
    "maximumpower55"
  ],
  "contact": {
    "homepage": "https://github.com/maximumpower55/Sapphire",
    "sources": "https://github.com/maximumpower55/Sapphire",
    "issues": "https://github.com/maximumpower55/Sapphire/issues"
  },
  "license": "MIT",
  "icon": "assets/sapphire/icon.png",
  "environment": "client",
  "entrypoints": {
  },
  "accessWidener": "sapphire.classtweaker",
  "mixins": [
    "sapphire-backend.mixins.json",
    "sapphire.mixins.json"
  ],
  "depends": {
    "minecraft": "=${minecraft_version}",
    "fabricloader": ">=${loader_version}"
  }
}
